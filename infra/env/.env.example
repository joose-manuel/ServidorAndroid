# =============================================================================
# ServidorAndroid / Edge Node — environment template
# Copy to .env / .env.staging / .env.prod and fill in real values.
# NEVER commit a real .env file (see .gitignore).
# =============================================================================

# ---------- API runtime ----------
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=api
API_CORS_ORIGINS=http://localhost:4200,http://localhost:8100
API_LOG_LEVEL=debug

# ---------- Supabase ----------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_JWT_SECRET=super-secret

# ---------- Database (PostgreSQL via TypeORM) ----------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=edge
DATABASE_PASSWORD=change-me
DATABASE_NAME=edge_node

# ---------- Modem (Sprint 1 — HU-01,02,03) ----------
MODEM_DEFAULT_IP=192.168.1.1
MODEM_DEFAULT_USER=admin
MODEM_DEFAULT_PASSWORD=change-me
MODEM_REQUEST_TIMEOUT_MS=5000

# ---------- Metrics & network audit (Sprint 2,3) ----------
METRICS_PING_INTERVAL_MS=180000          # 3 min, per docs 11.3
METRICS_PING_TARGET=8.8.8.8
NETWORK_SCAN_INTERVAL_MS=900000          # 15 min, per docs 11.3
NETWORK_SCAN_TIMEOUT_MS=2000
METRICS_LATENCY_ALERT_MS=300              # alert if > 300 ms (HU-05)

# ---------- Push (FCM) ----------
FCM_PROJECT_ID=your-firebase-project
FCM_PRIVATE_KEY_PATH=./secrets/fcm-private.json

# ---------- TURN / STUN (WebRTC camera + intercom) ----------
TURN_SERVER_URL=turn:turn.example.com:3478
TURN_SERVER_DOMAIN=turn.example.com
TURN_SHARED_SECRET=change-me-rotational
TURN_CREDENTIAL_TTL_SECONDS=3600
STUN_SERVER_URL=stun:stun.l.google.com:19302

# ---------- Frontend public ----------
PUBLIC_API_BASE_URL=http://localhost:3000/api
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
PUBLIC_TURN_SERVER_URL=turn:turn.example.com:3478
PUBLIC_STUN_SERVER_URL=stun:stun.l.google.com:19302