{
  "name": "edge",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/edge/src",
  "prefix": "app",
  "tags": ["scope:edge"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/edge",
        "index": "apps/edge/src/index.html",
        "browser": "apps/edge/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/edge/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "stylePreprocessorOptions": {
          "includePaths": ["node_modules"]
        },
        "assets": [{ "glob": "**/*", "input": "apps/edge/public" }],
        "styles": ["apps/edge/src/theme/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/edge/src/environments/environment.ts",
              "with": "apps/edge/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            { "type": "initial", "maximumWarning": "1mb", "maximumError": "3mb" },
            { "type": "anyComponentStyle", "maximumWarning": "6kb", "maximumError": "20kb" }
          ],
          "outputHashing": "all"
        },
        "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "options": { "host": "0.0.0.0", "port": 8100 },
      "configurations": {
        "production": { "buildTarget": "edge:build:production" },
        "development": { "buildTarget": "edge:build:development" }
      },
      "defaultConfiguration": "development"
    },
    "lint": { "executor": "@nx/eslint:lint" },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": { "jestConfig": "apps/edge/jest.config.ts" }
    },
    "cap:sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx cap sync android",
        "cwd": "apps/edge"
      },
      "dependsOn": ["build"]
    },
    "cap:open:android": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx cap open android",
        "cwd": "apps/edge"
      }
    }
  }
}
