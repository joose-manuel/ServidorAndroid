{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "tags": ["scope:api"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{options.outputPath}"],
      "options": {
        "command": "npx nest build --path tsconfig.app.json",
        "cwd": "apps/api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node --transpile-only --project apps/api/tsconfig.app.json -r tsconfig-paths/register apps/api/src/main.ts"
      }
    },
    "lint": { "executor": "@nx/eslint:lint" },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": { "jestConfig": "apps/api/jest.config.ts" }
    },
    "migration:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=apps/api/tsconfig.app.json node -r ts-node/register/transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/api/src/infra/database/datasource.ts",
        "cwd": "."
      }
    },
    "migration:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=apps/api/tsconfig.app.json node -r ts-node/register/transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/api/src/infra/database/datasource.ts"
      }
    },
    "migration:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=apps/api/tsconfig.app.json node -r ts-node/register/transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d apps/api/src/infra/database/datasource.ts"
      }
    }
  }
}
