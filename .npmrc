# Nx 18.x declares a peer range `@angular-devkit/build-angular >= 15.0.0 < 18.0.0`
# even though Angular 18 is supported in practice. `--legacy-peer-deps` lets
# npm resolve the graph without ignoring real conflicts elsewhere.
# See AGENTS.md → "Most-used commands" for context.
legacy-peer-deps=true

# Avoid creating package-lock.json that mixes platforms
fund=false
audit=false